# 至少配置一个 API Key 即可运行对应 provider 的 demo
# DeepSeek API Key（推荐，性价比高，通过 ChatOpenAI + baseURL 适配）
DEEPSEEK_API_KEY=sk-

# OpenAI API Key（可选，Agent demo 推荐使用 OpenAI，DeepSeek function calling 可能不稳定）
OPENAI_API_KEY=sk-

# Anthropic API Key（可选）
ANTHROPIC_API_KEY=sk-ant-

# Anthropic API Base URL（可选，用于代理/自定义端点）
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1
